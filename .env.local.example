# ── Supabase ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Cloudflare ────────────────────────────────────────────────────────────────
# Real rendering turns on as soon as ACCOUNT_ID + API_TOKEN are set.
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_KV_NAMESPACE_ID=        # Cloudflare KV (cache storage)
CLOUDFLARE_BROWSER_RENDERING_URL=  # OPTIONAL — override endpoint. Leave empty to use the
                                   # default: .../accounts/<ACCOUNT_ID>/browser-rendering/content

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_AGENCY=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_APP_URL is the origin integration snippets point crawlers at.
# Set it to your deployment (e.g. https://renderfast.vercel.app). Falls back to that.
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_SITE_URL=http://localhost:3000    # Change to your Vercel URL in production
CRON_SECRET=                                  # generate: openssl rand -hex 32
